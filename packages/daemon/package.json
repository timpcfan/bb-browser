{
  "name": "@bb-browser/daemon",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "bb-browser-daemon": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "tsx --test src/__tests__/*.test.ts",
    "test:drift": "tsx --test src/__tests__/protocol-drift.test.ts",
    "lint": "eslint src tsup.config.ts --ignore-pattern 'src/**/*.d.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bb-browser/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.7.0",
    "ws": "^8.17.1"
  }
}
